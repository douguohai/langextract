# Token authentication (comma-separated; leave empty to disable auth)
# API_TOKENS=your-token-1,your-token-2

# Model configuration
MODEL_ID=gemini-2.5-flash
MAX_WORKERS=8

# API keys (set only those you use)
GEMINI_API_KEY=your_gemini_key
OPENAI_API_KEY=your_openai_key
LANGEXTRACT_API_KEY=your_langextract_key
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service_account.json
GOOGLE_CLOUD_PROJECT=your_project_id

# OpenAI-compatible provider settings
# Set OPENAI_BASE_URL to use any OpenAI-compatible API (e.g. DashScope, Azure, local proxy)
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Set FORCE_OPENAI=1 to force OpenAI provider even without OPENAI_BASE_URL
# FORCE_OPENAI=1

# Optional network/proxy settings
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890
